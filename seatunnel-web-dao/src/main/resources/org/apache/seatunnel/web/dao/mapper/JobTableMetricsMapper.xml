<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="org.apache.seatunnel.web.dao.mapper.JobTableMetricsMapper">

    <resultMap id="JobTableMetricsVOResultMap"
               type="org.apache.seatunnel.web.spi.bean.vo.JobTableMetricsVO">
        <id property="id" column="id"/>
        <result property="jobInstanceId" column="jobInstanceId"/>
        <result property="jobDefinitionId" column="jobDefinitionId"/>
        <result property="pipelineId" column="pipelineId"/>
        <result property="sourceTable" column="sourceTable"/>
        <result property="sinkTable" column="sinkTable"/>
        <result property="readRowCount" column="readRowCount"/>
        <result property="writeRowCount" column="writeRowCount"/>
        <result property="readQps" column="readQps"/>
        <result property="writeQps" column="writeQps"/>
        <result property="readBytes" column="readBytes"/>
        <result property="writeBytes" column="writeBytes"/>
        <result property="readBps" column="readBps"/>
        <result property="writeBps" column="writeBps"/>
        <result property="status" column="status"/>
        <result property="errorMsg" column="errorMsg"/>
        <result property="createTime" column="createTime"/>
        <result property="updateTime" column="updateTime"/>
    </resultMap>

    <select id="selectByInstanceId" resultMap="JobTableMetricsVOResultMap">
        SELECT
            id AS id,
            job_instance_id AS jobInstanceId,
            job_definition_id AS jobDefinitionId,
            pipeline_id AS pipelineId,
            source_table AS sourceTable,
            sink_table AS sinkTable,
            read_row_count AS readRowCount,
            write_row_count AS writeRowCount,
            read_qps AS readQps,
            write_qps AS writeQps,
            read_bytes AS readBytes,
            write_bytes AS writeBytes,
            read_bps AS readBps,
            write_bps AS writeBps,
            status AS status,
            error_msg AS errorMsg,
            create_time AS createTime,
            update_time AS updateTime
        FROM t_seatunnel_job_table_metrics
        WHERE job_instance_id = #{instanceId}
        ORDER BY
            pipeline_id ASC,
            source_table ASC,
            sink_table ASC
    </select>

    <delete id="deleteByDefinitionId">
        DELETE FROM t_seatunnel_job_table_metrics
        WHERE job_definition_id = #{definitionId}
    </delete>

</mapper>